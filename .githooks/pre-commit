#!/usr/bin/env bash
set -euo pipefail

echo "Running gofmt check..."
make fmt-check

echo "Running golangci-lint..."
if ! command -v golangci-lint >/dev/null 2>&1; then
  echo "golangci-lint not found. Install from https://golangci-lint.run/ before committing." >&2
  exit 1
fi
make lint

echo "Running go tests..."
make test

echo "Regenerating docs to ensure sync..."
MARKDOWN_TRANSCLUSION_BIN=${MARKDOWN_TRANSCLUSION_BIN:-markdown-transclusion} make docs

echo "Pre-commit checks passed."
